const fs = require('fs');
const https = require('https');
const path = require('path');
const net = require('net');
const http = require('http');

// 🛡️ [安全防禦] 全域 Token 遮蔽器：複寫 console 輸出，防止 Stack Trace 洩露憑證
const sanitizeMessage = (msg) => {
    if (typeof msg !== 'string') return msg;
    return msg.replace(/\/bot\d+:[a-zA-Z0-9_-]+/g, '/bot<TELEGRAM_BOT_TOKEN_MASKED>');
};

const originalError = console.error;
console.error = function (...args) {
    const sanitized = args.map(arg => {
        if (arg instanceof Error) {
            arg.message = sanitizeMessage(arg.message);
            if (arg.stack) arg.stack = sanitizeMessage(arg.stack);
            return arg;
        }
        return sanitizeMessage(String(arg));
    });
    originalError.apply(console, sanitized);
};

const originalWarn = console.warn;
console.warn = function (...args) {
    const sanitized = args.map(arg => sanitizeMessage(String(arg)));
    originalWarn.apply(console, sanitized);
};

process.on('uncaughtException', (err) => {
    console.error('[系統崩潰防禦] 未捕獲的異常 (已遮蔽 Token):', err);
});
process.on('unhandledRejection', (reason) => {
    console.error('[系統崩潰防禦] 未處理的 Promise 拒絕 (已遮蔽 Token):', reason);
});

